{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "downlevelIteration": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "module": "commonjs",
    "outDir": "./dist",
    "resolveJsonModule": true,
    "rootDir": "./src",
    "sourceMap": true,
    "target": "es2020"
  },
  "exclude": ["**/node_modules/*"],
  "include": ["src/**/*.ts", "src/**/*.json"]
}
