{
  "extends": [
    "../../.eslintrc.json",
    "plugin:react/recommended",
    "plugin:react-hooks/recommended"
  ],
  "globals": {
    "process": true
  },
  "plugins": ["react"],
  "rules": {
    "react/forbid-prop-types": "off",
    "react/jsx-filename-extension": [1, { "extensions": [".js", ".jsx"] }],
    "react/no-array-index-key": "off"
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  }
}
