{
  "extends": [
    "../../.eslintrc.json",
    "plugin:react/recommended",
    "plugin:react-hooks/recommended"
  ],
  "globals": {
    "process": true
  },
  "rules": {
    "react/jsx-filename-extension": [1, { "extensions": [".ts", ".tsx"] }],
    "sort-keys": "warn",
    "sort-vars": "warn"
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  }
}
