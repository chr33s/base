{
  "name": "@chr33s/base",
  "version": "independent",
  "private": true,
  "engines": {
    "node": "14.x"
  },
  "workspaces": [
    "src/*"
  ],
  "npmClient": "yarn",
  "useWorkspaces": true,
  "scripts": {
    "clean": "rm -rf dist node_modules/.cache",
    "build": "rollup --config",
    "watch": "yarn build -- --watch",
    "dev": "yarn build && (yarn watch &) && nodemon --ignore ./dist ./src/server/index.mjs",
    "format": "prettier --write '**/*.{css,html,js,json,jsx,md,yml}'",
    "lint": "yarn lint:css && yarn lint:js",
    "lint:js": "eslint --fix 'src/**/*.{js,jsx}'",
    "lint:css": "stylelint --fix 'src/**/*.css'",
    "start": "node ./dist/server",
    "predeploy": "yarn clean && npm install --only=production",
    "deploy": "NODE_ENV=production yarn build",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --runInBand"
  },
  "devDependencies": {
    "@babel/cli": "7.13.10",
    "@babel/core": "7.13.10",
    "@babel/eslint-parser": "7.13.10",
    "@babel/node": "7.13.10",
    "@babel/plugin-proposal-class-properties": "7.13.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "7.13.8",
    "@babel/plugin-proposal-optional-chaining": "7.13.12",
    "@babel/preset-env": "7.13.10",
    "@babel/preset-react": "7.12.13",
    "@rollup/plugin-babel": "5.3.0",
    "@rollup/plugin-commonjs": "17.1.0",
    "@rollup/plugin-html": "0.2.3",
    "@rollup/plugin-json": "4.1.0",
    "@rollup/plugin-node-resolve": "11.2.0",
    "@rollup/plugin-replace": "2.4.1",
    "@rollup/plugin-url": "6.0.0",
    "autoprefixer": "10.2.5",
    "cssnano": "4.1.10",
    "eslint": "7.22.0",
    "eslint-config-prettier": "8.1.0",
    "eslint-plugin-jest": "24.3.2",
    "eslint-plugin-prettier": "3.3.1",
    "jest": "26.6.3",
    "jest-playwright-preset": "1.5.1",
    "nock": "13.0.11",
    "nodemon": "2.0.7",
    "playwright": "1.9.2",
    "playwright-cli": "0.180.0",
    "postcss": "8.2.8",
    "postcss-each": "1.0.0",
    "postcss-import": "14.0.0",
    "postcss-nested": "5.0.5",
    "postcss-preset-env": "6.7.0",
    "postcss-url": "10.1.3",
    "prettier": "2.2.1",
    "prettier-plugin-tailwind": "2.2.10",
    "rollup": "2.42.1",
    "rollup-plugin-copy": "3.4.0",
    "rollup-plugin-postcss": "4.0.0",
    "rollup-plugin-terser": "7.0.2",
    "stylelint": "13.12.0",
    "stylelint-config-prettier": "8.0.2",
    "stylelint-config-standard": "21.0.0",
    "supertest": "6.1.3",
    "tailwindcss": "2.0.4"
  }
}
