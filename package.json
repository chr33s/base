{
  "name": "@chr33s/base",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "12.x"
  },
  "scripts": {
    "clean": "rm -rf dist node_modules/.cache",
    "build": "rollup --config",
    "build:schema": "run() { for i in `find ./src/server -name '*.d.ts' -not -name 'index.d.ts' -not -path '*/node_modules/*' -exec basename {} \\;` ; do f=${i%.d.ts}; ts-json-schema-generator --no-top-ref --path ${i} --type $(echo ${f:0:1} | tr '[a-z]' '[A-Z]')${f:1} --out ./src/server/${f}.json --tsconfig ./tsconfig.base.json; done; exit 0; }; run",
    "postbuild:schema": "prettier --write './src/server/*.json' &> /dev/null",
    "watch": "npm run build -- --watch",
    "dev": "npm run build && (npm run watch &) && nodemon --ignore ./dist ./src/server/index.ts",
    "format": "prettier --write '**/*.{css,html,js,json,jsx,md,ts,tsx,yml}'",
    "lint": "npm run lint:css && npm run lint:ts && npm run lint:types",
    "lint:ts": "eslint --fix 'src/**/*.{ts,tsx}'",
    "lint:types": "run() { for i in `find . -iname 'tsconfig.json' -not -path '*/node_modules/*' -not -path '*/dist/*' -exec dirname {} \\;` ; do npx tsc --noEmit --project $i \"$@\"; done; exit 0; }; run",
    "lint:css": "stylelint --fix 'src/**/*.css'",
    "start": "node ./dist/server",
    "predeploy": "npm run clean && npm install --only=production",
    "deploy": "NODE_ENV=production npm run build",
    "test": "jest --runInBand",
    "test:watch": "npm run test -- --watchAll"
  },
  "dependencies": {
    "@sentry/node": "6.2.3",
    "@sentry/tracing": "6.2.3",
    "ajv": "7.2.3",
    "debug": "4.3.1",
    "express": "4.17.1",
    "node-fetch": "2.6.1"
  },
  "devDependencies": {
    "@babel/cli": "7.13.10",
    "@babel/core": "7.13.10",
    "@babel/eslint-parser": "7.13.10",
    "@babel/node": "7.13.10",
    "@babel/plugin-proposal-class-properties": "7.13.0",
    "@babel/preset-env": "7.13.10",
    "@babel/preset-react": "7.12.13",
    "@babel/preset-typescript": "7.13.0",
    "@rollup/plugin-babel": "5.3.0",
    "@rollup/plugin-commonjs": "17.1.0",
    "@rollup/plugin-html": "0.2.3",
    "@rollup/plugin-json": "4.1.0",
    "@rollup/plugin-node-resolve": "11.2.0",
    "@rollup/plugin-replace": "2.4.1",
    "@rollup/plugin-url": "6.0.0",
    "@sentry/integrations": "6.2.3",
    "@sentry/react": "6.2.3",
    "@tailwindcss/forms": "0.2.1",
    "@types/debug": "4.1.5",
    "@types/express": "4.17.11",
    "@types/jest": "26.0.21",
    "@types/node-fetch": "2.5.8",
    "@types/react": "17.0.3",
    "@types/react-dom": "17.0.2",
    "@types/supertest": "2.0.10",
    "@typescript-eslint/eslint-plugin": "4.18.0",
    "@typescript-eslint/parser": "4.18.0",
    "acorn-jsx": "5.3.1",
    "autoprefixer": "10.2.5",
    "babel-eslint": "10.1.0",
    "cssnano": "4.1.10",
    "eslint": "7.22.0",
    "eslint-config-prettier": "8.1.0",
    "eslint-plugin-jest": "24.3.2",
    "eslint-plugin-jest-playwright": "0.2.1",
    "eslint-plugin-prettier": "3.3.1",
    "eslint-plugin-react": "7.22.0",
    "eslint-plugin-react-hooks": "4.2.0",
    "immutability-helper": "3.1.1",
    "jest": "26.6.3",
    "jest-playwright-preset": "1.5.1",
    "nock": "13.0.11",
    "nodemon": "2.0.7",
    "playwright": "1.9.2",
    "playwright-cli": "0.180.0",
    "postcss": "8.2.8",
    "postcss-each": "1.0.0",
    "postcss-import": "14.0.0",
    "postcss-nested": "5.0.5",
    "postcss-preset-env": "6.7.0",
    "postcss-url": "10.1.3",
    "prettier": "2.2.1",
    "prettier-plugin-tailwind": "2.2.10",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "react-router-dom": "5.2.0",
    "rollup": "2.42.2",
    "rollup-plugin-copy": "3.4.0",
    "rollup-plugin-postcss": "4.0.0",
    "rollup-plugin-terser": "7.0.2",
    "stylelint": "13.12.0",
    "stylelint-config-prettier": "8.0.2",
    "stylelint-config-standard": "21.0.0",
    "supertest": "6.1.3",
    "tailwindcss": "2.0.4",
    "ts-json-schema-generator": "0.89.0",
    "ts-node": "9.1.1",
    "tslib": "2.1.0",
    "typescript": "4.2.3"
  },
  "browserslist": [
    "Chrome 78"
  ]
}
