{
  "name": "@chr33s/base",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "14.x"
  },
  "workspaces": [
    "src/*"
  ],
  "npmClient": "yarn",
  "useWorkspaces": true,
  "scripts": {
    "format": "prettier --write '**/*.{css,gql,html,js,json,jsx,md,mjs,yml}'",
    "lint:js": "eslint --fix 'src/**/*.{gql,js,jsx,mjs}'"
  },
  "devDependencies": {
    "@graphql-eslint/eslint-plugin": "0.9.0",
    "babel-plugin-import-graphql": "2.8.1",
    "eslint": "7.22.0",
    "eslint-config-prettier": "8.1.0",
    "eslint-plugin-prettier": "3.3.1",
    "graphql": "15.5.0",
    "graphql-tag": "2.11.0",
    "prettier": "2.2.1"
  }
}
