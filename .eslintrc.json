{
  "env": {
    "es6": true,
    "jest": true,
    "node": true
  },
  "extends": ["eslint:recommended", "plugin:prettier/recommended"],
  "globals": {
    "browser": true,
    "page": true
  },
  "parser": "@babel/eslint-parser",
  "plugins": ["prettier", "jest"],
  "root": true,
  "rules": {
    "sort-imports": ["error"]
  }
}
