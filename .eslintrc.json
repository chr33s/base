{
  "overrides": [
    {
      "files": ["src/client/**/*.gql"],
      "parser": "@graphql-eslint/eslint-plugin",
      "parserOptions": {
        "schema": "./src/server/schema.gql"
      },
      "plugins": ["@graphql-eslint"],
      "rules": {
        "no-unreachable-types": ["error"],
        "no-deprecated": ["error"],
        "unique-fragment-name": ["error"],
        "unique-operation-name": ["error"],
        "validate-against-schema": ["error"],
        "no-hashtag-description": ["error"],
        "no-anonymous-operations": ["error"],
        "no-operation-name-suffix": ["error"],
        "require-deprecation-reason": ["error"],
        "avoid-operation-name-prefix": ["error"],
        "selection-set-depth": ["error"],
        "no-case-insensitive-enum-values-duplicates": ["error"],
        "require-description": ["error"],
        "require-id-when-available": ["error"],
        "description-style": ["error"],
        "avoid-duplicate-fields": ["error"],
        "naming-convention": ["error"],
        "input-name": ["error"],
        "strict-id-in-types": ["error"],
        "prettier": ["error"],
        "executable-definitions": ["error"],
        "fields-on-correct-type": ["error"],
        "fragments-on-composite-type": ["error"],
        "known-argument-names": ["error"],
        "known-directives": ["error"],
        "known-fragment-names": ["error"],
        "known-type-names": ["error"],
        "lone-anonymous-operation": ["error"],
        "lone-schema-definition": ["error"],
        "no-fragment-cycles": ["error"],
        "no-undefined-variables": ["error"],
        "no-unused-fragments": ["error"],
        "no-unused-variables": ["error"],
        "overlapping-fields-can-be-merged": ["error"],
        "possible-fragment-spread": ["error"],
        "possible-type-extension": ["error"],
        "provided-required-arguments": ["error"],
        "scalar-leafs": ["error"],
        "one-field-subscriptions": ["error"],
        "unique-argument-names": ["error"],
        "unique-directive-names": ["error"],
        "unique-directive-names-per-location": ["error"],
        "unique-enum-value-names": ["error"],
        "unique-field-definition-names": ["error"],
        "unique-input-field-names": ["error"],
        "unique-operation-types": ["error"],
        "unique-type-names": ["error"],
        "unique-variable-names": ["error"],
        "value-literals-of-correct-type": ["error"],
        "variables-are-input-types": ["error"],
        "variables-in-allowed-position": ["error"]
      }
    }
  ]
}
